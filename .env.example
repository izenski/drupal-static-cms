# Drupal Configuration
DRUPAL_BASE_URL=https://your-drupal-site.com
DRUPAL_API_USER=api_user
DRUPAL_API_PASSWORD=api_password

# AWS S3 Configuration
S3_BUCKET_NAME=your-static-site-bucket
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Webhook Configuration (for webhook receiver)
DRUPAL_WEBHOOK_SECRET=generate-with-python-secrets-token-urlsafe-32
WEBHOOK_PORT=5000
WEBHOOK_ENABLED=true

# Optional: Flask Debug Mode (development only)
FLASK_DEBUG=false
